<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="UTF-8">
    <title>GamePedia</title>
    <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
<%- include('../Templates/header'); -%>
<main class="main">
    <h1>Додати нову гру</h1>
    
    <section>
        <h2>Автозаповнення через IGDB</h2>
        <label>
            Назва гри для пошуку:
            <input id="igdb-title" type="text" placeholder="Наприклад: The Witcher 3">
        </label>
        <button id="igdb-search-button" type="button" class="btn">Знайти в IGDB</button>
        <div id="igdb-results"></div>
    </section>

    <form id="create-game-form" class="auth-form" action="/games/add" method="post">
        <label>Назва гри:<br><input type="text" name="title" required></label><br>
        <label>Жанр:<br><input type="text" name="genre" required></label><br>
        <label>Рік випуску:<br><input type="number" name="release_year"></label><br>
        <label>Розробник:<br><input type="text" name="developer"></label><br>
        <label>Опис:<br><textarea name="description"></textarea></label><br>
        <label>Зображення (URL):<br><input type="text" name="imageURL"></label><br>
        <label>Трейлер:<br><input type="text" name="trailerYoutubeId"></label><br>
        <label>Зображення банера (URL):<br><input type="text" name="bannerURL"></label><br>
        <button type="submit" class="btn">Додати</button>
    </form>
</main>

<script src="/js/create-new-game.js"></script>

</body>
</html>
